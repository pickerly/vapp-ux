<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VAPP UX Weekly Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.js" integrity="sha384-iU8HYtnGQ8Cy4zl7gbNMOhsDTTKX02BTXptVP/vqAWIaTfM7isw76iyZCsjL2eVi" crossorigin="anonymous"></script>
<style>
:root {
  --red: #DA291C;
  --black: #000000;
  --dgray: #575757;
  --mgray: #878787;
  --lgray: #DADADA;
  --bg: #F2F2F2;
  --card: #ffffff;
  --border: #E0E0E0;
  --text: #000000;
  --muted: #575757;
  --good-bg:#f0faf0;--good-border:#b8e6b8;--good-text:#1a6b1a;
  --warn-bg:#fff8f0;--warn-border:#f5c888;--warn-text:#8a4a00;
  --bad-bg:#fff0f0;--bad-border:#f5b8b8;--bad-text:#8a0000;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Outfit',sans-serif;font-weight:300;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;}
h1,h2,h3,.semi{font-weight:600;}

/* HEADER */
.header{background:#fff;border-bottom:3px solid var(--red);padding:18px 28px;display:flex;align-items:center;justify-content:space-between;}
.header-left{display:flex;align-items:center;gap:12px;}
.dot{width:10px;height:10px;border-radius:50%;background:var(--red);}
.header-title{font-size:18px;font-weight:600;letter-spacing:.3px;}
.header-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.header-right{display:flex;align-items:center;gap:10px;}
.badge{background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:5px 12px;font-size:12px;color:var(--muted);}
.refresh-btn{background:var(--red);color:#fff;border:none;border-radius:6px;padding:7px 16px;font-size:12px;font-family:'Outfit',sans-serif;font-weight:600;cursor:pointer;letter-spacing:.3px;}
.refresh-btn:hover{background:#b81e12;}

/* TABS */
.tabs-bar{background:#fff;border-bottom:1px solid var(--border);padding:0 28px;display:flex;gap:4px;}
.tab-btn{background:none;border:none;border-bottom:3px solid transparent;padding:14px 20px;font-family:'Outfit',sans-serif;font-weight:600;font-size:13px;cursor:pointer;color:var(--muted);letter-spacing:.3px;transition:color .15s;}
.tab-btn:hover{color:var(--text);}
.tab-btn.active{color:var(--red);border-bottom-color:var(--red);}

/* CONTENT */
.panel{display:none;padding:24px 28px;max-width:1200px;}
.panel.active{display:block;}

/* KPI GRID */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
@media(max-width:900px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
.kpi{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:18px 20px;}
.kpi-label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;}
.kpi-value{font-size:26px;font-weight:600;line-height:1.1;}
.kpi-sub{font-size:11px;color:var(--muted);margin-top:4px;}
.kpi.accent{border-top:3px solid var(--red);}

/* SECTION */
.section-title{font-size:13px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin:24px 0 12px;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:780px){.two-col{grid-template-columns:1fr;}}

/* CARD */
.card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px;}
.card-title{font-size:12px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:14px;}

/* CLARITY ROW */
.clarity-row{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;}
.cl-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 20px;display:flex;align-items:center;gap:14px;}
.cl-icon{width:40px;height:40px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.cl-icon.red{background:#fff0f0;}
.cl-icon.orange{background:#fff8f0;}
.cl-icon.blue{background:#f0f4ff;}
.cl-label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
.cl-value{font-size:22px;font-weight:600;margin-top:2px;}
.cl-note{font-size:11px;color:var(--muted);margin-top:1px;}

/* CHART */
.chart-wrap{height:220px;position:relative;}

/* CHANNEL TABLE */
.ch-table{width:100%;border-collapse:collapse;}
.ch-table th{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;padding:6px 8px;text-align:left;border-bottom:1px solid var(--border);}
.ch-table td{padding:8px 8px;font-size:13px;border-bottom:1px solid #f0f0f0;}
.ch-table tr:last-child td{border-bottom:none;}
.conv-bar-wrap{display:flex;align-items:center;gap:8px;}
.conv-bar-bg{flex:1;height:5px;background:var(--bg);border-radius:3px;overflow:hidden;}
.conv-bar-fill{height:100%;background:var(--red);border-radius:3px;}

/* RAGE PAGES */
.rage-list{list-style:none;}
.rage-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #f0f0f0;gap:10px;}
.rage-item:last-child{border-bottom:none;}
.rage-url{font-size:12px;color:var(--dgray);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.rage-pill{background:var(--bad-bg);color:var(--bad-text);border:1px solid var(--bad-border);border-radius:12px;padding:2px 10px;font-size:11px;font-weight:600;white-space:nowrap;}

/* INSIGHTS */
.insight-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:0;}
@media(max-width:780px){.insight-grid{grid-template-columns:1fr;}}
.insight{border-radius:10px;padding:16px 18px;border:1px solid;}
.insight.good{background:var(--good-bg);border-color:var(--good-border);}
.insight.warn{background:var(--warn-bg);border-color:var(--warn-border);}
.insight.bad{background:var(--bad-bg);border-color:var(--bad-border);}
.insight-header{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.insight-icon{font-size:16px;}
.insight-title{font-size:12px;font-weight:600;}
.insight.good .insight-title{color:var(--good-text);}
.insight.warn .insight-title{color:var(--warn-text);}
.insight.bad .insight-title{color:var(--bad-text);}
.insight-text{font-size:12px;line-height:1.5;color:var(--dgray);}
.insight-action{margin-top:8px;font-size:11px;font-weight:600;color:var(--muted);background:rgba(0,0,0,.05);border-radius:5px;padding:5px 8px;}

/* COMPARISON */
.compare-table{width:100%;border-collapse:collapse;}
.compare-table th{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;padding:10px 14px;border-bottom:2px solid var(--border);}
.compare-table th.red{color:var(--red);}
.compare-table td{padding:11px 14px;font-size:13px;border-bottom:1px solid #f5f5f5;}
.compare-table tr:last-child td{border-bottom:none;}
.compare-table td:first-child{font-weight:600;font-size:11px;text-transform:uppercase;color:var(--muted);letter-spacing:.4px;}
.winner{font-weight:700;color:var(--text);}
.loser{color:var(--mgray);}

/* STEPS */
.steps{list-style:none;display:flex;flex-direction:column;gap:8px;}
.step{display:flex;gap:10px;align-items:flex-start;padding:10px 12px;background:var(--bg);border-radius:8px;}
.step-num{font-size:11px;font-weight:700;color:var(--red);background:#fff0f0;border-radius:5px;padding:2px 7px;white-space:nowrap;flex-shrink:0;margin-top:1px;}
.step-text{font-size:12px;line-height:1.5;}
</style>
</head>
